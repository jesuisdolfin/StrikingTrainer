@page "/"
@inject IJSRuntime JS
@using System.Timers

<PageTitle>StrikingTrainer</PageTitle>

<div style="text-align:center; font-family: sans-serif; padding: 10px; max-width: 500px; margin: 0 auto;">
    <h1 style="font-size: 2.5rem; font-weight: bold; margin-bottom: 10px;">StrikingTrainer</h1>
    
    <div style="font-size: 5rem; font-weight: bold; margin: 20px 0; color: #222;">
        @TimeDisplay
    </div>

    <div style="background: #333; color: #fff; padding: 30px 20px; border-radius: 12px; min-height: 120px; display: flex; align-items: center; justify-content: center;">
        <h2 style="margin: 0; font-size: 2rem;">@CurrentCombo</h2>
    </div>

    <div style="margin-top: 30px;">
        @if (!isRunning)
        {
            <div style="margin-bottom: 20px; display: flex; flex-direction: column; align-items: stretch; gap: 8px;">
                <label style="font-size: 1.2rem; font-weight: bold; color: #555; text-align: left;">Strike Types</label>
                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                    <button @onclick="() => includePunches = !includePunches" style="@GetButtonStyle(includePunches)">Punches</button>
                    <button @onclick="() => includeKicks = !includeKicks" style="@GetButtonStyle(includeKicks)">Kicks</button>
                    <button @onclick="() => includeDefenses = !includeDefenses" style="@GetButtonStyle(includeDefenses)">Defenses</button>
                </div>
            </div>
            
            <button @onclick="StartWorkout" style="width: 100%; padding: 20px; font-size: 1.5rem; font-weight: bold; background: #28a745; color: white; border: none; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                START ROUND
            </button>
        }
        else
        {
            <button @onclick="StopWorkout" style="width: 100%; padding: 20px; font-size: 1.5rem; font-weight: bold; background: #dc3545; color: white; border: none; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                STOP
            </button>
        }
    </div>
</div>

@code {
    private string TimeDisplay = "03:00";
    private string CurrentCombo = "Ready?";
    private bool isRunning = false;
    private System.Timers.Timer roundTimer = default!;
    private int secondsLeft = 180;

    // Arsenal Toggles
    private bool includePunches = true;
    private bool includeKicks = true;
    private bool includeDefenses = true;

    private string GetButtonStyle(bool isActive)
    {
        return isActive 
            ? "flex: 1 1 calc(50% - 5px); padding: 15px 10px; font-size: 1.1rem; font-weight: bold; border-radius: 8px; border: 2px solid #0a58ca; background: #0d6efd; color: #fff; transition: all 0.2s ease-in-out; box-shadow: 0 4px 6px rgba(0,0,0,0.2);"
            : "flex: 1 1 calc(50% - 5px); padding: 15px 10px; font-size: 1.1rem; font-weight: bold; border-radius: 8px; border: 2px solid #ccc; background: #fff; color: #555; transition: all 0.2s ease-in-out;";
    }

    private List<string> activeLeadMoves = new();
    private List<string> activeRearMoves = new();

    private void UpdateActivePools()
    {
        activeLeadMoves.Clear();
        activeRearMoves.Clear();

        if (includePunches) 
        {
            activeLeadMoves.AddRange(new[] { "1", "3", "5" });
            activeRearMoves.AddRange(new[] { "2", "4", "6" });
        }
        if (includeKicks) 
        {
            activeLeadMoves.AddRange(new[] { "Lead Kick", "Lead Knee", "Lead Teep" });
            activeRearMoves.AddRange(new[] { "Rear Kick", "Rear Knee", "Rear Teep" });
        }
        if (includeDefenses) 
        {
            activeLeadMoves.AddRange(new[] { "Slip Left", "Roll Left", "Cover Left", "Lead Check", "Lead Teep" });
            activeRearMoves.AddRange(new[] { "Slip Right", "Roll Right", "Cover Right", "Rear Check", "Rear Teep" });
        }
        
        // Remove duplicates if both Kicks and Defenses include Teeps
        activeLeadMoves = activeLeadMoves.Distinct().ToList();
        activeRearMoves = activeRearMoves.Distinct().ToList();

        // Fallback if none selected
        if (activeLeadMoves.Count == 0) activeLeadMoves.Add("1");
        if (activeRearMoves.Count == 0) activeRearMoves.Add("2");
    }

    private Random rng = new Random();

    protected override void OnInitialized()
    {
        roundTimer = new System.Timers.Timer(1000);
        roundTimer.Elapsed += OnTimerTick;
    }

    private async Task StartWorkout()
    {
        isRunning = true;
        
        CurrentCombo = "Get Ready...";
        StateHasChanged();
        
        // Eagerly initialize speech synthesis within the user interaction context (button click).
        // Say "Round Starting"
        await JS.InvokeVoidAsync("speak", "Round Starting");
        
        await Task.Delay(2000);
        
        if (!isRunning) return;

        for (int i = 5; i > 0; i--)
        {
            if (!isRunning) return; // Cancelled
            CurrentCombo = $"Starting in {i}...";
            StateHasChanged();
            await JS.InvokeVoidAsync("speak", i.ToString());
            await Task.Delay(1000);
        }

        if (!isRunning) return; // Final check

        CurrentCombo = "Ready?";
        secondsLeft = 180;
        TimeDisplay = "03:00";
        
        UpdateActivePools();
        
        StateHasChanged();

        roundTimer.Start();
        _ = ComboLoop(); // Run on the main UI thread via yielding, instead of Task.Run (background thread)
    }

    private void StopWorkout()
    {
        isRunning = false;
        roundTimer.Stop();
        
        // Cancel any ongoing speech
        JS.InvokeVoidAsync("eval", "window.speechSynthesis.cancel()").AsTask();
    }

    private void OnTimerTick(object? sender, ElapsedEventArgs e)
    {
        secondsLeft--;
        int mins = secondsLeft / 60;
        int secs = secondsLeft % 60;
        TimeDisplay = $"{mins:D2}:{secs:D2}";
        
        if (secondsLeft <= 0)
        {
            isRunning = false;
            roundTimer.Stop();
            InvokeAsync(async () => {
                await JS.InvokeVoidAsync("eval", "window.speechSynthesis.cancel(); window.speak('Round Ending');");
            });
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task ComboLoop()
    {
        while (isRunning)
        {
            // Generate a 2-4 hit combo
            List<string> comboList = new List<string>();
            bool nextIsLead = rng.Next(0, 2) == 0;

            for (int i = 0; i < rng.Next(2, 5); i++)
            {
                var pool = nextIsLead ? activeLeadMoves : activeRearMoves;
                comboList.Add(pool[rng.Next(pool.Count)]);
                nextIsLead = !nextIsLead;
            }

            CurrentCombo = "";
            foreach (var strike in comboList)
            {
                if (!isRunning) break;

                CurrentCombo += (CurrentCombo.Length == 0 ? "" : " - ") + strike;
                StateHasChanged();
                
                // Speak each individual strike
                await JS.InvokeVoidAsync("speak", strike);
                
                // Rhythmic pause matching pad-work between strikes
                await Task.Delay(1200);
            }

            if (!isRunning) break;

            // Wait 2-4 seconds before the next entire combination
            await Task.Delay(rng.Next(2000, 4000));
        }
    }
}